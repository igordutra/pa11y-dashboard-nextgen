PORT=3000
MONGO_URI=mongodb://localhost:27017/pa11y-dashboard
CLIENT_URL=http://localhost:8080
NODE_ENV=development
TRUST_PROXY=false
SCREENSHOTS_DIR=./screenshots
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ==========================================
# Authentication & Role-Based Access Control
# ==========================================
# Set to 'true' to require login. If 'false', the app is public (everyone is an admin).
AUTH_ENABLED=false

# Required if AUTH_ENABLED=true. Generate a strong random string (e.g., using 'openssl rand -hex 32').
JWT_SECRET=your_super_secret_jwt_key_here

# ------------------------------------------
# External Identity Providers (OAuth2)
# ------------------------------------------

# GitHub OAuth
# 1. Go to GitHub -> Settings -> Developer Settings -> OAuth Apps -> New OAuth App
# 2. Set "Authorization callback URL" to: http://localhost:8080/api/auth/github/callback (or your production domain)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
# 1. Go to Google Cloud Console -> APIs & Services -> Credentials
# 2. Create "OAuth 2.0 Client ID" (Web application)
# 3. Add "Authorized redirect URIs": http://localhost:8080/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Auth0
AUTH0_CLIENT_ID=your_auth0_id
AUTH0_CLIENT_SECRET=your_auth0_secret
AUTH0_DOMAIN=your-tenant.auth0.com

# Keycloak
KEYCLOAK_CLIENT_ID=your_keycloak_id
KEYCLOAK_CLIENT_SECRET=your_keycloak_secret
KEYCLOAK_BASE_URL=https://your-keycloak-server/auth

# Note: The system is designed to be easily extensible. To add new providers:
# 1. Add their client ID/secret to this file.
# 2. Map them in 'server/config/index.ts'.
# 3. Register the new provider using '@fastify/oauth2' in 'server/plugins/auth.ts'.
# 4. Create a callback route in 'server/routes/auth.ts'.
